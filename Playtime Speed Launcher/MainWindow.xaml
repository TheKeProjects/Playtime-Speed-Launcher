<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SpeedrunLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SpeedrunLauncher"
    Title="Poppy Playtime — Speedrun Launcher"
    WindowState="Maximized"
    WindowStyle="None"
    ResizeMode="NoResize">

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#070C12"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- ── TOP STATUS BAR ── -->
        <Border Grid.Row="0" Background="#08111A"
                BorderBrush="#0D2030" BorderThickness="0,0,0,1"/>
        <TextBlock Grid.Row="0"
                   x:Name="VersionLabel"
                   Text="v1.0.0"
                   FontFamily="Cascadia Code, Consolas, Courier New"
                   FontSize="10" Foreground="#1A3A55"
                   HorizontalAlignment="Right" VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

        <!-- ── CHAPTER CARDS ── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalAlignment="Center">
            <StackPanel x:Name="CardsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="40,8"/>
        </ScrollViewer>

        <!-- ── CHAPTER INFO ── -->
        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,8">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#FFAA00"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="12" Foreground="#2A5A7A"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <Button Background="Transparent" BorderThickness="0"
                        Padding="0" Click="VersionBtn_Click"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0">
                    <Border BorderBrush="#1A3A55" BorderThickness="1"
                            CornerRadius="3" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="VersionText"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13" Foreground="#00CCAA"/>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;"
                                       FontSize="10" Foreground="#1A4060"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>

            <TextBlock x:Name="DescriptionText"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="14" Foreground="#2A5A7A"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       TextAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ── ACTION BUTTONS ── -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,14">

            <Grid>
                <Button x:Name="SettingsButton"
                        Width="58" Height="58"
                        local:ButtonHelper.CornerRadius="5"
                        Background="#0A1825" BorderBrush="#112233"
                        BorderThickness="2"
                        ToolTipService.ToolTip="Configuración"
                        Click="SettingsButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;"
                               FontSize="22" Foreground="#3A6A8A"/>
                </Button>
                <Button x:Name="SettingsUpdateBadge"
                        Width="20" Height="20"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-5,-5,0"
                        Background="#CC2200" BorderThickness="0"
                        local:ButtonHelper.CornerRadius="10"
                        Visibility="Collapsed"
                        Panel.ZIndex="10"
                        Click="SettingsUpdateBadge_Click">
                    <TextBlock Text="!" FontSize="11" FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <Button x:Name="PlayButton"
                    Height="58" MinWidth="260"
                    local:ButtonHelper.CornerRadius="5"
                    Background="#00CCAA" BorderThickness="0"
                    Click="PlayButton_Click"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;"
                               FontSize="16" Foreground="#060C12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="PlayButtonText"
                               Text="JUGAR CAPÍTULO"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#060C12"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Button>

            <Button x:Name="QuitButton"
                    Width="58" Height="58"
                    local:ButtonHelper.CornerRadius="5"
                    Background="#1A0606" BorderBrush="#440000"
                    BorderThickness="1"
                    Click="QuitButton_Click"
                    Margin="8,0,0,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7E8;"
                           FontSize="20" Foreground="#CC3333"/>
            </Button>

        </StackPanel>

        <!-- ── BOTTOM BAR ── -->
        <Border Grid.Row="5" Background="#08111A"
                BorderBrush="#0D2030" BorderThickness="0,1,0,0"/>

        <!-- ── VERSIONS OVERLAY ── -->
        <Grid x:Name="VersionsOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">

            <Border Width="700" Height="500"
                    Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <Grid Margin="6,0">
                            <Button x:Name="PrevChapterBtn"
                                    Background="Transparent" BorderThickness="0"
                                    Width="38" Height="38"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Click="PrevChapterBtn_Click">
                                <TextBlock Text="&#x2190;"
                                           FontFamily="Consolas" FontSize="20"
                                           Foreground="#00CCAA"/>
                            </Button>

                            <TextBlock x:Name="VersionsHeader"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#00CCAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="NextChapterBtn"
                                    Background="Transparent" BorderThickness="0"
                                    Width="38" Height="38"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="NextChapterBtn_Click">
                                <TextBlock Text="&#x2192;"
                                           FontFamily="Consolas" FontSize="20"
                                           Foreground="#00CCAA"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="InstallsList"
                                    Margin="12,10"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Grid Margin="14,0">
                            <Button x:Name="AddInstallBtn"
                                    Height="36" MinWidth="120"
                                    local:ButtonHelper.CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Click="AddInstallBtn_Click">
                                <TextBlock x:Name="AddInstallBtnText"
                                           Text="AÑADIR"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#00CCAA"/>
                            </Button>
                            <Button x:Name="TogglePresetsBtn"
                                    Height="36" MinWidth="150"
                                    local:ButtonHelper.CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Click="TogglePresetsBtn_Click"/>
                            <Button x:Name="CloseVersionsBtn"
                                    Height="36" MinWidth="120"
                                    local:ButtonHelper.CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="CloseVersionsBtn_Click">
                                <TextBlock x:Name="CloseVersionsBtnText"
                                           Text="VOLVER"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#3A6A8A"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── SETTINGS OVERLAY ── -->
        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">
            <Border Width="420" Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="SettingsHeaderText"
                                   Text="[ CONFIGURACIÓN ]"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13" FontWeight="Bold" Foreground="#00CCAA"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,18">

                        <!-- Updates row -->
                        <Button x:Name="OpenUpdatesBtn"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                local:ButtonHelper.CornerRadius="4"
                                Background="#060F18" BorderBrush="#0D2535" BorderThickness="1"
                                Padding="12,10" Margin="0,0,0,16"
                                Click="OpenUpdatesBtn_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="OpenUpdatesBtnIcon"
                                               FontFamily="Segoe MDL2 Assets" Text="&#xE74A;"
                                               FontSize="16" Foreground="#2A5A7A"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="OpenUpdatesBtnText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="OpenUpdatesBtnBadge"
                                           Grid.Column="1"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="10" FontWeight="Bold" Foreground="#CC4422"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Border BorderBrush="#0D2030" BorderThickness="0,0,0,1" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="SoundEffectsLabel"
                                       Text="Efectos de sonido"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#8AAABB"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="VolumeValueText"
                                       Text="50%"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="11" Foreground="#00CCAA"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="50"
                                SmallChange="1"
                                ValueChanged="VolumeSlider_ValueChanged"
                                Margin="0,0,0,12"/>
                        <Grid>
                            <TextBlock x:Name="LanguageLabel"
                                       Text="Idioma"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#8AAABB"
                                       VerticalAlignment="Center"/>

                            <!-- Custom animated language selector -->
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">

                                <Button x:Name="LangSelectorBtn"
                                        Height="30" MinWidth="130"
                                        local:ButtonHelper.CornerRadius="4"
                                        Background="#0A1825" BorderBrush="#1A3A55" BorderThickness="1"
                                        Padding="10,0,8,0"
                                        PreviewMouseDown="LangSelectorBtn_PreviewMouseDown"
                                        Click="LangSelectorBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="LangSelectedText"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"
                                                   VerticalAlignment="Center"/>
                                        <Image x:Name="LangSelectedFlagImg"
                                               Width="20" Height="14"
                                               Margin="6,0,8,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <TextBlock x:Name="LangChevron"
                                                   FontFamily="Segoe MDL2 Assets" Text="&#xE70D;"
                                                   FontSize="9" Foreground="#2A5A7A"
                                                   VerticalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="LangChevronRotate" CenterX="5" CenterY="5"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Popup x:Name="LangPopup"
                                       PlacementTarget="{Binding ElementName=LangSelectorBtn}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       Opened="LangPopup_Opened"
                                       Closed="LangPopup_Closed">
                                    <Border x:Name="LangDropdownBorder"
                                            Background="#09141E"
                                            BorderBrush="#153048" BorderThickness="1"
                                            CornerRadius="0,0,4,4"
                                            MinWidth="130"
                                            RenderTransformOrigin="0.5,0"
                                            Opacity="0">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="LangDropdownScale" ScaleY="0"/>
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <Button Tag="es" Click="LangOptionBtn_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Padding="10,8,10,8">
                                                <Grid MinWidth="110">
                                                    <TextBlock Text="Español"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="11" Foreground="#8AAABB"
                                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <Image x:Name="EsFlagImg" Width="20" Height="14"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Grid>
                                            </Button>
                                            <Button Tag="en" Click="LangOptionBtn_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Padding="10,8,10,8">
                                                <Grid MinWidth="110">
                                                    <TextBlock Text="English"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="11" Foreground="#8AAABB"
                                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <Image x:Name="EnFlagImg" Width="20" Height="14"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Button x:Name="CloseSettingsBtn"
                                Height="36" MinWidth="120"
                                local:ButtonHelper.CornerRadius="3"
                                Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,14,0"
                                Click="CloseSettingsBtn_Click">
                            <TextBlock x:Name="CloseSettingsBtnText"
                                       Text="VOLVER"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── UPDATES OVERLAY ── -->
        <Grid x:Name="UpdatesOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">

            <Border Width="700" Height="540"
                    Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="UpdatesHeaderText"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13" FontWeight="Bold" Foreground="#00CCAA"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- CHECK VIEW -->
                    <ScrollViewer x:Name="UpdateCheckView"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Visible">
                        <StackPanel Margin="20,14">

                            <Button Background="#060F18" BorderBrush="#0D2535" BorderThickness="1"
                                    local:ButtonHelper.CornerRadius="4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,12" Click="CheckUpdatesBanner_Click"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74A;"
                                               FontSize="22" Foreground="#00CCAA"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Margin="14,0,0,0">
                                        <TextBlock x:Name="UpdateCurrentVersionLabel"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="10" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateCurrentVersionText"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="20" FontWeight="Bold" Foreground="#00CCAA"/>
                                        <TextBlock x:Name="UpdateCheckHint"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="10" Foreground="#1A3A50"
                                                   FontStyle="Italic"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button x:Name="UpdateStatusBtn"
                                    local:ButtonHelper.CornerRadius="4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,12" Visibility="Collapsed"
                                    Click="UpdateStatusBtn_Click"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="UpdateStatusIcon"
                                               FontFamily="Segoe MDL2 Assets" Text="&#xE74A;"
                                               FontSize="22" Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Margin="14,0,0,0">
                                        <TextBlock x:Name="UpdateStatusTitle"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="UpdateStatusMessage"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12" Foreground="White" Opacity="0.85"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button x:Name="GbUpdateBtn"
                                    Background="#F4821A" BorderThickness="0"
                                    local:ButtonHelper.CornerRadius="4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,12" Visibility="Collapsed"
                                    Click="GbUpdateBtn_Click"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE774;"
                                               FontSize="22" Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Margin="14,0,0,0">
                                        <TextBlock x:Name="GbUpdateTitle"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="GbUpdateMessage"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12" Foreground="White" Opacity="0.85"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Border x:Name="UpdateDetailsBorder"
                                    Background="#060F18" BorderBrush="#0D2535" BorderThickness="1"
                                    CornerRadius="4" Padding="16,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="UpdateDetailsLabel"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="10" FontWeight="Bold" Foreground="#00CCAA"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="UpdateLatestVersionLabel" Grid.Row="0" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateLatestVersionText" Grid.Row="0" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                        <TextBlock x:Name="UpdateFileNameLabel" Grid.Row="1" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateFileNameText" Grid.Row="1" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                        <TextBlock x:Name="UpdateFileSizeLabel" Grid.Row="2" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateFileSizeText" Grid.Row="2" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- INSTALL VIEW -->
                    <Grid x:Name="UpdateInstallView"
                          Grid.Row="1"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#060F18"
                                BorderBrush="#0D2030" BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xECC5;"
                                           FontSize="22" Foreground="#00CCAA"
                                           VerticalAlignment="Center"/>
                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock x:Name="InstallTitleText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="14" FontWeight="Bold" Foreground="#00CCAA"/>
                                    <TextBlock x:Name="InstallSubtitleText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" Foreground="#2A5A7A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#060F18"
                                BorderBrush="#0D2030" BorderThickness="0,0,0,1"
                                Margin="12,8,12,4" CornerRadius="4" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="WhatsNewLabel" Grid.Row="0"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="10" FontWeight="Bold" Foreground="#00CCAA"
                                           Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="ChangelogText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="12" Foreground="#8AAABB"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Grid Margin="14,0">

                            <StackPanel x:Name="DownloadProgressPanel"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="UpdateDownloadProgressText"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" Foreground="#00CCAA"
                                           VerticalAlignment="Center"/>
                                <ProgressBar x:Name="UpdateDownloadProgressBar"
                                             Value="0" Maximum="100"
                                             Width="200" Height="6" VerticalAlignment="Center"
                                             Margin="12,0,0,0"/>
                            </StackPanel>

                            <StackPanel x:Name="InstallButtonsPanel"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Button x:Name="AcceptInstallBtn"
                                        Height="36" MinWidth="200"
                                        local:ButtonHelper.CornerRadius="3"
                                        Background="#00CCAA" BorderThickness="0"
                                        Click="AcceptInstallBtn_Click">
                                    <TextBlock x:Name="AcceptInstallBtnText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" FontWeight="Bold" Foreground="#060C12"/>
                                </Button>
                                <Button x:Name="CancelInstallBtn"
                                        Height="36" MinWidth="100"
                                        local:ButtonHelper.CornerRadius="3"
                                        Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                        Click="CancelInstallBtn_Click"
                                        Margin="8,0,0,0">
                                    <TextBlock x:Name="CancelInstallBtnText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                                </Button>
                            </StackPanel>

                            <Button x:Name="CloseUpdatesBtn"
                                    Height="36" MinWidth="120"
                                    local:ButtonHelper.CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="CloseUpdatesBtn_Click">
                                <TextBlock x:Name="CloseUpdatesBtnText"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- ── INTRO VIDEO OVERLAY ── -->
        <Grid x:Name="IntroOverlay"
              Grid.RowSpan="6"
              Background="Black"
              MouseDown="IntroOverlay_MouseDown">
            <MediaElement x:Name="IntroPlayer"
                          LoadedBehavior="Manual"
                          Stretch="Uniform"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>
            <TextBlock x:Name="IntroSkipText"
                       Text="[ clic para saltar ]"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="9" Foreground="#1A2A38"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,16,12"/>
        </Grid>

    </Grid>
</Window>
