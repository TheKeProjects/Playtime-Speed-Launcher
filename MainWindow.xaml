<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SpeedrunLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SpeedrunLauncher"
    Title="Poppy Playtime — Speedrun Launcher">

    <Grid RequestedTheme="Dark">

        <!-- Solid dark background -->
        <Grid.Background>
            <SolidColorBrush Color="#070C12"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>    <!-- top status bar -->
            <RowDefinition Height="Auto"/>  <!-- header title -->
            <RowDefinition Height="*"/>     <!-- chapter cards -->
            <RowDefinition Height="Auto"/>  <!-- chapter info -->
            <RowDefinition Height="Auto"/>  <!-- action buttons -->
            <RowDefinition Height="38"/>    <!-- bottom bar -->
        </Grid.RowDefinitions>

        <!-- ── TOP STATUS BAR ── -->
        <Border Grid.Row="0" Background="#08111A"
                BorderBrush="#0D2030" BorderThickness="0,0,0,1"/>
        <Button x:Name="UpdatesTopBtn"
                Grid.Row="0"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Padding="12,0"
                Click="UpdatesTopBtn_Click">
            <TextBlock x:Name="UpdatesTopBtnText"
                       Text="v1.0.0"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="10" Foreground="#1A3A55"/>
        </Button>

        <!-- ── HEADER (hidden) ── -->

        <!-- ── CHAPTER CARDS ── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollMode="Auto"
                      VerticalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalAlignment="Center">
            <StackPanel x:Name="CardsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Padding="40,8"/>
        </ScrollViewer>

        <!-- ── CHAPTER INFO ── -->
        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,8"
                    Spacing="6">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="14" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#FFAA00"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="12" Foreground="#2A5A7A"
                           VerticalAlignment="Center"/>
                <Button Background="Transparent" BorderThickness="0"
                        Padding="0" Click="VersionBtn_Click"
                        VerticalAlignment="Center">
                    <Border BorderBrush="#1A3A55" BorderThickness="1"
                            CornerRadius="3" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="VersionText"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13" Foreground="#00CCAA"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="10"
                                      Foreground="#1A4060"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>

            <TextBlock x:Name="DescriptionText"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="14" Foreground="#2A5A7A"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- ── ACTION BUTTONS ── -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="0,4,0,14">

            <Button x:Name="SettingsButton"
                    Width="58" Height="58" CornerRadius="5"
                    Background="#0A1825" BorderBrush="#112233"
                    BorderThickness="1"
                    ToolTipService.ToolTip="Configuración"
                    Click="SettingsButton_Click">
                <FontIcon Glyph="&#xE713;" FontSize="22" Foreground="#3A6A8A"/>
            </Button>

            <Button x:Name="PlayButton"
                    Height="58" MinWidth="260" CornerRadius="5"
                    Background="#00CCAA" BorderThickness="0"
                    Click="PlayButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="#060C12"/>
                    <TextBlock x:Name="PlayButtonText"
                               Text="JUGAR CAPÍTULO"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#060C12"/>
                </StackPanel>
            </Button>

            <Button x:Name="QuitButton"
                    Width="58" Height="58" CornerRadius="5"
                    Background="#1A0606" BorderBrush="#440000"
                    BorderThickness="1"
                    Click="QuitButton_Click">
                <FontIcon Glyph="&#xE7E8;" FontSize="20" Foreground="#CC3333"/>
            </Button>

        </StackPanel>

        <!-- ── BOTTOM BAR ── -->
        <Border Grid.Row="5" Background="#08111A"
                BorderBrush="#0D2030" BorderThickness="0,1,0,0"/>

        <!-- ── VERSIONS OVERLAY ── -->
        <Grid x:Name="VersionsOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">

            <Border Width="700" Height="500"
                    Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <!-- Header with prev/next chapter arrows -->
                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <Grid Margin="6,0">
                            <Button x:Name="PrevChapterBtn"
                                    Background="Transparent" BorderThickness="0"
                                    Width="38" Height="38"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Click="PrevChapterBtn_Click">
                                <TextBlock Text="&#x2190;"
                                           FontFamily="Consolas" FontSize="20"
                                           Foreground="#00CCAA"/>
                            </Button>

                            <TextBlock x:Name="VersionsHeader"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#00CCAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="NextChapterBtn"
                                    Background="Transparent" BorderThickness="0"
                                    Width="38" Height="38"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="NextChapterBtn_Click">
                                <TextBlock Text="&#x2192;"
                                           FontFamily="Consolas" FontSize="20"
                                           Foreground="#00CCAA"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Installations list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="InstallsList"
                                    Spacing="2" Padding="12,10"/>
                    </ScrollViewer>

                    <!-- Bottom buttons -->
                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Grid Margin="14,0">
                            <Button x:Name="AddInstallBtn"
                                    Height="36" MinWidth="120" CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Click="AddInstallBtn_Click">
                                <TextBlock x:Name="AddInstallBtnText"
                                           Text="AÑADIR"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#00CCAA"/>
                            </Button>
                            <Button x:Name="TogglePresetsBtn"
                                    Height="36" MinWidth="150" CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Click="TogglePresetsBtn_Click"/>
                            <Button x:Name="CloseVersionsBtn"
                                    Height="36" MinWidth="120" CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="CloseVersionsBtn_Click">
                                <TextBlock x:Name="CloseVersionsBtnText"
                                           Text="VOLVER"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#3A6A8A"/>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- ── SETTINGS OVERLAY ── -->
        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">
            <Border Width="420" Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="SettingsHeaderText"
                                   Text="[ CONFIGURACIÓN ]"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13" FontWeight="Bold" Foreground="#00CCAA"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,18" Spacing="12">
                        <Grid>
                            <TextBlock x:Name="SoundEffectsLabel"
                                       Text="Efectos de sonido"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#8AAABB"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="VolumeValueText"
                                       Text="50%"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="11" Foreground="#00CCAA"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="50"
                                StepFrequency="1"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                        <Grid>
                            <TextBlock x:Name="LanguageLabel"
                                       Text="Idioma"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#8AAABB"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="LanguageComboBox"
                                      HorizontalAlignment="Right"
                                      RequestedTheme="Dark"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBoxItem Content="Español" Tag="es"/>
                                <ComboBoxItem Content="English" Tag="en"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Button x:Name="CloseSettingsBtn"
                                Height="36" MinWidth="120" CornerRadius="3"
                                Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,14,0"
                                Click="CloseSettingsBtn_Click">
                            <TextBlock x:Name="CloseSettingsBtnText"
                                       Text="VOLVER"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>


        <!-- ── UPDATES OVERLAY ── -->
        <Grid x:Name="UpdatesOverlay"
              Grid.RowSpan="6"
              Visibility="Collapsed"
              Background="#BB000000">

            <Border Width="700" Height="540"
                    Background="#09141E"
                    BorderBrush="#153048" BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="UpdatesHeaderText"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13" FontWeight="Bold" Foreground="#00CCAA"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- CHECK VIEW -->
                    <ScrollViewer x:Name="UpdateCheckView"
                                  Grid.Row="1"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Visible">
                        <StackPanel Spacing="10" Padding="20,14">

                            <!-- Current version banner -->
                            <Button Background="#060F18" BorderBrush="#0D2535" BorderThickness="1"
                                    CornerRadius="4" HorizontalAlignment="Stretch"
                                    Padding="16,12" Click="CheckUpdatesBanner_Click">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <FontIcon Glyph="&#xE74A;" FontSize="22" Foreground="#00CCAA"
                                              VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="UpdateCurrentVersionLabel"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="10" Foreground="#2A5A7A"/>
                                        <TextBlock FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="20" FontWeight="Bold" Foreground="#00CCAA">
                                            <Run Text="v"/><Run Text="1.0.0"/>
                                        </TextBlock>
                                        <TextBlock x:Name="UpdateCheckHint"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="10" Foreground="#1A3A50"
                                                   FontStyle="Italic"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Status banner (hidden until checked) -->
                            <Button x:Name="UpdateStatusBtn"
                                    CornerRadius="4" HorizontalAlignment="Stretch"
                                    Padding="16,12" Visibility="Collapsed"
                                    Click="UpdateStatusBtn_Click">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <FontIcon x:Name="UpdateStatusIcon"
                                              Glyph="&#xE74A;" FontSize="22" Foreground="White"
                                              VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="UpdateStatusTitle"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="UpdateStatusMessage"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12" Foreground="White" Opacity="0.85"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- GameBanana banner -->
                            <Button x:Name="GbUpdateBtn"
                                    Background="#F4821A" BorderThickness="0"
                                    CornerRadius="4" HorizontalAlignment="Stretch"
                                    Padding="16,12" Visibility="Collapsed"
                                    Click="GbUpdateBtn_Click">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <FontIcon Glyph="&#xE774;" FontSize="22" Foreground="White"
                                              VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="GbUpdateTitle"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="GbUpdateMessage"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12" Foreground="White" Opacity="0.85"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Version details (shown when update available) -->
                            <Border x:Name="UpdateDetailsBorder"
                                    Background="#060F18" BorderBrush="#0D2535" BorderThickness="1"
                                    CornerRadius="4" Padding="16,12" Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="UpdateDetailsLabel"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="10" FontWeight="Bold" Foreground="#00CCAA"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="UpdateLatestVersionLabel" Grid.Row="0" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateLatestVersionText" Grid.Row="0" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                        <TextBlock x:Name="UpdateFileNameLabel" Grid.Row="1" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateFileNameText" Grid.Row="1" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                        <TextBlock x:Name="UpdateFileSizeLabel" Grid.Row="2" Grid.Column="0"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#2A5A7A"/>
                                        <TextBlock x:Name="UpdateFileSizeText" Grid.Row="2" Grid.Column="1"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11" Foreground="#8AAABB"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- INSTALL VIEW -->
                    <Grid x:Name="UpdateInstallView"
                          Grid.Row="1"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Install header -->
                        <Border Grid.Row="0" Background="#060F18"
                                BorderBrush="#0D2030" BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xECC5;" FontSize="22" Foreground="#00CCAA"
                                          VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock x:Name="InstallTitleText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="14" FontWeight="Bold" Foreground="#00CCAA"/>
                                    <TextBlock x:Name="InstallSubtitleText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" Foreground="#2A5A7A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Changelog -->
                        <Border Grid.Row="1" Background="#060F18"
                                BorderBrush="#0D2030" BorderThickness="0,0,0,1"
                                Margin="12,8,12,4" CornerRadius="4" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="WhatsNewLabel" Grid.Row="0"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="10" FontWeight="Bold" Foreground="#00CCAA"
                                           Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollMode="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="ChangelogText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="12" Foreground="#8AAABB"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#060F18"
                            BorderBrush="#0D2030" BorderThickness="0,1,0,0">
                        <Grid Margin="14,0">

                            <!-- Download progress (shown while downloading) -->
                            <StackPanel x:Name="DownloadProgressPanel"
                                        Orientation="Horizontal" Spacing="12"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="UpdateDownloadProgressText"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" Foreground="#00CCAA"
                                           VerticalAlignment="Center"/>
                                <ProgressBar x:Name="UpdateDownloadProgressBar"
                                             Value="0" Maximum="100"
                                             Width="200" Height="6" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Install buttons (shown in install view, not downloading) -->
                            <StackPanel x:Name="InstallButtonsPanel"
                                        Orientation="Horizontal" Spacing="8"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Button x:Name="AcceptInstallBtn"
                                        Height="36" MinWidth="200" CornerRadius="3"
                                        Background="#00CCAA" BorderThickness="0"
                                        Click="AcceptInstallBtn_Click">
                                    <TextBlock x:Name="AcceptInstallBtnText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" FontWeight="Bold" Foreground="#060C12"/>
                                </Button>
                                <Button x:Name="CancelInstallBtn"
                                        Height="36" MinWidth="100" CornerRadius="3"
                                        Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                        Click="CancelInstallBtn_Click">
                                    <TextBlock x:Name="CancelInstallBtnText"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                                </Button>
                            </StackPanel>

                            <!-- Close button (always) -->
                            <Button x:Name="CloseUpdatesBtn"
                                    Height="36" MinWidth="120" CornerRadius="3"
                                    Background="#0A1825" BorderBrush="#0D2535" BorderThickness="1"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="CloseUpdatesBtn_Click">
                                <TextBlock x:Name="CloseUpdatesBtnText"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="11" FontWeight="Bold" Foreground="#3A6A8A"/>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- ── INTRO VIDEO OVERLAY ── -->
        <Grid x:Name="IntroOverlay"
              Grid.RowSpan="6"
              Background="Black"
              PointerPressed="IntroOverlay_PointerPressed">
            <MediaPlayerElement x:Name="IntroPlayer"
                                AreTransportControlsEnabled="False"
                                Stretch="Uniform"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            <TextBlock x:Name="IntroSkipText"
                       Text="[ clic para saltar ]"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="9" Foreground="#1A2A38"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,16,12"/>
        </Grid>

    </Grid>
</Window>
